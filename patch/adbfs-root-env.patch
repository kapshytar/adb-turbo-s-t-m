+// Optional device-side root prefix (e.g. "/storage/emulated/0").
+// Empty => expose whole device root. Set via ADBFS_ROOT env var.
+string g_root;
+static string remap_path(const char* path) {
+    if (g_root.empty()) return string(path);
+    if (path[0] == '/' && path[1] == '\0') return g_root; // "/" -> root
+    return g_root + path; // path always begins with '/'
+}
